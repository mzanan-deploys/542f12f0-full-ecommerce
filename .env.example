# =============================================================================
# Next.js
# =============================================================================
NEXT_PUBLIC_APP_URL=

# =============================================================================
# Vercel Postgres / Neon (auto-provisioned by Vercel integration)
# =============================================================================
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=

# =============================================================================
# Auth (Better Auth, self-hosted: no external service)
# =============================================================================
# Any long random string, e.g. `openssl rand -base64 32`
BETTER_AUTH_SECRET=

# =============================================================================
# Vercel Blob (auto-provisioned by Vercel integration)
# =============================================================================
BLOB_READ_WRITE_TOKEN=

# =============================================================================
# Resend (manual setup, see README)
# =============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SUPPORT_EMAIL=

# =============================================================================
# Stripe (manual setup, see README)
# =============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# Store branding (used everywhere: set these to customize)
# =============================================================================
NEXT_PUBLIC_STORE_NAME=Store
NEXT_PUBLIC_STORE_TITLE=Store: Modern ecommerce
NEXT_PUBLIC_STORE_DESCRIPTION=Production-ready ecommerce template.
NEXT_PUBLIC_STORE_KEYWORDS=ecommerce,store,collections
NEXT_PUBLIC_STORE_CURRENCY=USD
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_TWITTER_HANDLE=
NEXT_PUBLIC_CATEGORY_PRIMARY_LABEL=Day
NEXT_PUBLIC_CATEGORY_PRIMARY_DESCRIPTION=Daytime collection
NEXT_PUBLIC_CATEGORY_SECONDARY_LABEL=Night
NEXT_PUBLIC_CATEGORY_SECONDARY_DESCRIPTION=Evening collection

# =============================================================================
# Attribution. Paid add-on, purchase at:
# https://itsmatias.com/api/buy/remove-attribution-ecommerce
# =============================================================================
# Footer shows "Built by Matias Zanan" by default. Set to "true" only if you
# bought the Remove Attribution add-on. Hiding it without the purchase
# violates the LICENSE. Full terms at https://itsmatias.com/terms.
NEXT_PUBLIC_HIDE_ATTRIBUTION=
